{
    "name": "kelsoncm/php-fwf",
    "description": "PHP library for reading, writing, and parsing Fixed Width Files (FWF)",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Kelson da Costa Medeiros",
            "email": "kelsoncm@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "Kelsoncm\\Fwf\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kelsoncm\\Fwf\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
